@model List<FederationPlatform.Application.DTOs.OrganizationDto>
@{
    ViewData["Title"] = "تشکل‌ها و سندیکاها";
}

<div class="container-fluid py-4" dir="rtl">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-3">🏢 تشکل‌ها و سندیکاها</h2>
            <p class="text-muted">تشکل‌ها و سندیکاهای همکار فدراسیون اقتصاد سلامت</p>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center">
            <i class="fas fa-info-circle"></i>
            تشکلی برای نمایش وجود ندارد
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var org in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm hover-lift">
                        <div class="card-body text-center">
                            @if (!string.IsNullOrEmpty(org.LogoUrl))
                            {
                                <img src="@org.LogoUrl" alt="@org.Name" class="mb-3" style="max-height: 100px; max-width: 100%;">
                            }
                            else
                            {
                                <div class="mb-3">
                                    <i class="fas fa-building fa-4x text-muted"></i>
                                </div>
                            }
                            
                            <h5 class="card-title">@org.Name</h5>
                            
                            @if (!string.IsNullOrEmpty(org.Description))
                            {
                                <p class="card-text text-muted small">
                                    @if (org.Description.Length > 100)
                                    {
                                        @org.Description.Substring(0, 100)<text>...</text>
                                    }
                                    else
                                    {
                                        @org.Description
                                    }
                                </p>
                            }

                            <a href="@Url.Action("Details", new { id = org.Id })" class="btn btn-sm btn-primary mt-2">
                                مشاهده جزئیات
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .hover-lift {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }
</style>
