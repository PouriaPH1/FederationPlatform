@model List<FederationPlatform.Application.DTOs.UniversityReportDto>

@{
    ViewBag.Title = "گزارش دانشگاه‌ها";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-12">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h3 class="mb-0">
                        <i class="fas fa-university me-2"></i>
                        گزارش دانشگاه‌ها
                    </h3>
                </div>

                <div class="card-body">
                    <!-- Export Button -->
                    <div class="mb-3">
                        <form method="post" action="@Url.Action("ExportUniversitiesExcel", "Report")" style="display: inline;">
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-download me-2"></i>
                                دانلود Excel
                            </button>
                        </form>
                    </div>

                    <!-- Overall Statistics -->
                    <div class="row mb-4">
                        <div class="col-md-4">
                            <div class="stat-card-green">
                                <h5>تعداد دانشگاه‌ها</h5>
                                <p class="stat-value">@Model.Count</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="stat-card-green">
                                <h5>کل فعالیت‌ها</h5>
                                <p class="stat-value">@Model.Sum(u => u.TotalActivities)</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="stat-card-green">
                                <h5>میانگین نرخ تایید</h5>
                                <p class="stat-value">@(Model.Count > 0 ? Math.Round(Model.Average(u => u.ApprovalRate), 1) : 0)%</p>
                            </div>
                        </div>
                    </div>

                    <!-- Table -->
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>دانشگاه</th>
                                    <th>کل فعالیت‌ها</th>
                                    <th>تایید شده</th>
                                    <th>درانتظار</th>
                                    <th>رد شده</th>
                                    <th>نرخ تایید %</th>
                                    <th>اقسام برتر</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Count == 0)
                                {
                                    <tr>
                                        <td colspan="7" class="text-center text-muted">
                                            <i class="fas fa-inbox me-2"></i>
                                            اطلاعاتی یافت نشد
                                        </td>
                                    </tr>
                                }
                                @foreach (var university in Model)
                                {
                                    <tr>
                                        <td><strong>@university.UniversityName</strong></td>
                                        <td>@university.TotalActivities</td>
                                        <td>
                                            <span class="badge bg-success">@university.ApprovedActivities</span>
                                        </td>
                                        <td>
                                            <span class="badge bg-warning">@university.PendingActivities</span>
                                        </td>
                                        <td>
                                            <span class="badge bg-danger">@university.RejectedActivities</span>
                                        </td>
                                        <td>
                                            <div class="progress" style="width: 100px;">
                                                @{
                                                    int rate = (int)university.ApprovalRate;
                                                }
                                                <div class="progress-bar" role="progressbar" style="width: @rate%" aria-valuenow="@rate" aria-valuemin="0" aria-valuemax="100">@rate%</div>
                                            </div>
                                        </td>
                                        <td>@string.Join("، ", university.TopActivityTypes)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.stat-card-green {
    background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
    color: white;
    padding: 20px;
    border-radius: 8px;
    text-align: center;
    margin-bottom: 20px;
}

.stat-card-green h5 {
    font-size: 0.9rem;
    opacity: 0.9;
    margin-bottom: 10px;
}

.stat-value {
    font-size: 2rem;
    font-weight: bold;
    margin: 0;
}

.table-hover tbody tr:hover {
    background-color: #f5f5f5;
}

.progress {
    height: 20px;
    background-color: #e9ecef;
    border-radius: 4px;
}

.progress-bar {
    background-color: #28a745;
    font-size: 0.75rem;
    line-height: 20px;
}
</style>
