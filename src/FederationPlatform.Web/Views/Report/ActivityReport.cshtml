@model List<FederationPlatform.Application.DTOs.ActivityReportDto>

@{
    ViewBag.Title = "گزارش فعالیت‌ها";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-12">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">
                        <i class="fas fa-file-alt me-2"></i>
                        گزارش فعالیت‌ها
                    </h3>
                </div>

                <div class="card-body">
                    <!-- Filter Section -->
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <form method="get" action="@Url.Action("ActivityReport", "Report")" class="form-inline">
                                <div class="form-group me-3 mb-3">
                                    <label class="me-2">فیلتر بر اساس:</label>
                                    <select name="universityId" class="form-select form-select-sm me-2">
                                        <option value="">همه دانشگاه‌ها</option>
                                        @* Would be populated dynamically *@
                                    </select>
                                </div>
                                <div class="form-group me-3 mb-3">
                                    <select name="status" class="form-select form-select-sm me-2">
                                        <option value="">همه وضعیت‌ها</option>
                                        <option value="Approved">تایید شده</option>
                                        <option value="Pending">درانتظار</option>
                                        <option value="Rejected">رد شده</option>
                                    </select>
                                </div>
                                <button type="submit" class="btn btn-sm btn-primary me-2">
                                    <i class="fas fa-search me-1"></i> جستجو
                                </button>
                            </form>
                        </div>
                    </div>

                    <!-- Export Button -->
                    <div class="mb-3">
                        <form method="post" action="@Url.Action("ExportActivitiesExcel", "Report")" style="display: inline;">
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-download me-2"></i>
                                دانلود Excel
                            </button>
                        </form>
                    </div>

                    <!-- Statistics -->
                    <div class="row mb-4">
                        <div class="col-md-3">
                            <div class="stat-card">
                                <h5>کل فعالیت‌ها</h5>
                                <p class="stat-value">@Model.Count</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="stat-card">
                                <h5>تایید شده</h5>
                                <p class="stat-value">@Model.Count(a => a.Status == "Approved")</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="stat-card">
                                <h5>درانتظار</h5>
                                <p class="stat-value">@Model.Count(a => a.Status == "Pending")</p>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <div class="stat-card">
                                <h5>رد شده</h5>
                                <p class="stat-value">@Model.Count(a => a.Status == "Rejected")</p>
                            </div>
                        </div>
                    </div>

                    <!-- Table -->
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="table-light">
                                <tr>
                                    <th>عنوان</th>
                                    <th>نوع</th>
                                    <th>دانشگاه</th>
                                    <th>نماینده</th>
                                    <th>تاریخ شروع</th>
                                    <th>وضعیت</th>
                                    <th>فایل‌ها</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Count == 0)
                                {
                                    <tr>
                                        <td colspan="7" class="text-center text-muted">
                                            <i class="fas fa-inbox me-2"></i>
                                            فعالیتی یافت نشد
                                        </td>
                                    </tr>
                                }
                                @foreach (var activity in Model)
                                {
                                    <tr>
                                        <td>
                                            <strong>@activity.Title</strong>
                                        </td>
                                        <td>@activity.ActivityType</td>
                                        <td>@activity.UniversityName</td>
                                        <td>@activity.RepresentativeName</td>
                                        <td>@activity.StartDate.ToString("yyyy-MM-dd")</td>
                                        <td>
                                            @{
                                                var badgeClass = activity.Status == "Approved" ? "bg-success" :
                                                               activity.Status == "Pending" ? "bg-warning" :
                                                               "bg-danger";
                                            }
                                            <span class="badge @badgeClass">@activity.Status</span>
                                        </td>
                                        <td>@activity.FileCount</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.stat-card {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 20px;
    border-radius: 8px;
    text-align: center;
    margin-bottom: 20px;
}

.stat-card h5 {
    font-size: 0.9rem;
    opacity: 0.9;
    margin-bottom: 10px;
}

.stat-value {
    font-size: 2rem;
    font-weight: bold;
    margin: 0;
}

.table-hover tbody tr:hover {
    background-color: #f5f5f5;
}

.badge {
    padding: 5px 10px;
    font-size: 0.85rem;
}
</style>
