@model List<FederationPlatform.Application.DTOs.NewsDto>
@{
    ViewData["Title"] = "اخبار";
}

<div class="container-fluid py-4" dir="rtl">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="mb-3">📰 اخبار و اطلاعیه‌ها</h2>
        </div>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info text-center">
            <i class="fas fa-info-circle"></i>
            خبری برای نمایش وجود ندارد
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var news in Model)
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm hover-lift">
                        @if (!string.IsNullOrEmpty(news.ImageUrl))
                        {
                            <img src="@news.ImageUrl" class="card-img-top" alt="@news.Title" style="height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                                <i class="fas fa-newspaper fa-3x text-muted"></i>
                            </div>
                        }
                        <div class="card-body">
                            <h5 class="card-title">@news.Title</h5>
                            <p class="card-text text-muted">
                                @if (news.Content.Length > 150)
                                {
                                    @news.Content.Substring(0, 150)<text>...</text>
                                }
                                else
                                {
                                    @news.Content
                                }
                            </p>
                            <div class="d-flex justify-content-between align-items-center">
                                <small class="text-muted">
                                    <i class="far fa-calendar"></i>
                                    @news.CreatedAt.ToString("yyyy/MM/dd")
                                </small>
                                <a href="@Url.Action("Details", new { id = news.Id })" class="btn btn-sm btn-primary">
                                    مشاهده جزئیات
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (ViewBag.TotalPages > 1)
        {
            <nav aria-label="Page navigation" class="mt-4">
                <ul class="pagination justify-content-center">
                    @if (ViewBag.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Index", new { page = ViewBag.CurrentPage - 1 })">قبلی</a>
                        </li>
                    }

                    @for (int i = 1; i <= ViewBag.TotalPages; i++)
                    {
                        <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Action("Index", new { page = i })">@i</a>
                        </li>
                    }

                    @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("Index", new { page = ViewBag.CurrentPage + 1 })">بعدی</a>
                        </li>
                    }
                </ul>
            </nav>
        }
    }
</div>

<style>
    .hover-lift {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-lift:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1);
    }
</style>
