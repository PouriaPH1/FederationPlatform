@model FederationPlatform.Application.DTOs.NewsDto
@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-4" dir="rtl">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">خانه</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index")">اخبار</a></li>
                    <li class="breadcrumb-item active">@Model.Title</li>
                </ol>
            </nav>

            <div class="card shadow-sm">
                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                {
                    <img src="@Model.ImageUrl" class="card-img-top" alt="@Model.Title" style="max-height: 400px; object-fit: cover;">
                }

                <div class="card-body">
                    <h1 class="card-title mb-3">@Model.Title</h1>
                    
                    <div class="text-muted mb-4">
                        <i class="far fa-calendar"></i>
                        <small>@Model.CreatedAt.ToString("yyyy/MM/dd HH:mm")</small>
                    </div>

                    <div class="news-content">
                        @Html.Raw(Model.Content.Replace("\n", "<br>"))
                    </div>
                </div>
            </div>

            <div class="mt-3">
                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    <i class="fas fa-arrow-right"></i>
                    بازگشت به لیست اخبار
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .news-content {
        font-size: 1.1rem;
        line-height: 1.8;
        text-align: justify;
    }
</style>
