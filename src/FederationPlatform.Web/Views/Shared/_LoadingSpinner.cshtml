@* Loading Spinner - Partial View *@

<div class="spinner-container" id="@ViewBag.SpinnerId" style="display: @(ViewBag.Visible == true ? "flex" : "none");">
    <div class="spinner-overlay"></div>
    <div class="spinner-content">
        <div class="spinner-animation"></div>
        <p style="margin-top: 15px; color: #666;">@(ViewBag.Message ?? "درحال بارگذاری...")</p>
    </div>
</div>

<style>
    .spinner-container {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9998;
    }

    .spinner-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.3);
    }

    .spinner-content {
        position: relative;
        text-align: center;
    }

    .spinner-animation {
        width: 50px;
        height: 50px;
        border: 4px solid #f3f3f3;
        border-top: 4px solid #1E40AF;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @@keyframes spin {
        0% {
            transform: rotate(0deg);
        }
        100% {
            transform: rotate(360deg);
        }
    }
</style>

<script>
    function showSpinner() {
        const spinner = document.getElementById('@ViewBag.SpinnerId');
        if (spinner) spinner.style.display = 'flex';
    }

    function hideSpinner() {
        const spinner = document.getElementById('@ViewBag.SpinnerId');
        if (spinner) spinner.style.display = 'none';
    }
</script>
