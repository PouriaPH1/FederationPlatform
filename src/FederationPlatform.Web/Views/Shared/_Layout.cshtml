<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title | پلتفرم فدراسیون اقتصاد سلامت</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@100..900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@3.9.1/dist/chart.min.js"></script>
    
    <!-- Persian Date Picker -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/persian-datepicker@1.2.1/dist/css/persian-datepicker.min.css">
    <script src="https://cdn.jsdelivr.net/npm/persian-datepicker@1.2.1/dist/js/persian-datepicker.min.js"></script>
    
    <!-- Main CSS Files -->
    <link rel="stylesheet" href="~/css/style.css">
    <link rel="stylesheet" href="~/css/dashboard.css">
    <link rel="stylesheet" href="~/css/animations.css">
    <link rel="stylesheet" href="~/css/responsive.css">
    <link rel="stylesheet" href="~/css/notifications.css">
</head>
<body>
    <div id="app">
        <!-- Navigation -->
        @await Html.PartialAsync("_NavBar")

        <!-- Main Content -->
        <div id="mainContent" class="main-content">
            @if (User.Identity?.IsAuthenticated ?? false)
            {
                <!-- Sidebar for authenticated users -->
                @await Html.PartialAsync("_SideBar")
                <div class="content-wrapper">
                    @RenderBody()
                </div>
            }
            else
            {
                <!-- No sidebar for public pages -->
                <div class="container-fluid">
                    @RenderBody()
                </div>
            }
        </div>

        <!-- Footer -->
        @await Html.PartialAsync("_Footer")
    </div>

    <!-- Notifications Container -->
    <div id="notifications-container"></div>

    <!-- Scripts -->
    <script src="~/js/form-validation.js"></script>
    <script src="~/js/notifications.js"></script>
    <script src="~/js/notification-manager.js"></script>
    <script src="~/js/app.js"></script>
    <script src="~/js/auth.js"></script>
    <script src="~/js/sidebar.js"></script>
    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <script src="~/js/charts.js"></script>
    }
    <script src="~/js/file-upload.js"></script>
    <script src="~/js/search-filter.js"></script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
