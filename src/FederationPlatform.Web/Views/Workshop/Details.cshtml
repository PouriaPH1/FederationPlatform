@model FederationPlatform.Application.DTOs.WorkshopDto
@{
    ViewData["Title"] = Model.Title;
    var isUpcoming = Model.StartDate > DateTime.Now;
    var isPast = Model.EndDate < DateTime.Now;
}

<div class="container py-4" dir="rtl">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="@Url.Action("Index", "Home")">خانه</a></li>
                    <li class="breadcrumb-item"><a href="@Url.Action("Index")">کارگاه‌ها</a></li>
                    <li class="breadcrumb-item active">@Model.Title</li>
                </ol>
            </nav>

            <div class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <h1 class="card-title">@Model.Title</h1>
                        @if (isUpcoming)
                        {
                            <span class="badge bg-success fs-6">آینده</span>
                        }
                        else if (isPast)
                        {
                            <span class="badge bg-secondary fs-6">گذشته</span>
                        }
                        else
                        {
                            <span class="badge bg-primary fs-6">در حال برگزاری</span>
                        }
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            <p class="mb-2">
                                <i class="far fa-calendar text-primary"></i>
                                <strong>تاریخ شروع:</strong> @Model.StartDate.ToString("yyyy/MM/dd HH:mm")
                            </p>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-2">
                                <i class="far fa-calendar text-danger"></i>
                                <strong>تاریخ پایان:</strong> @Model.EndDate.ToString("yyyy/MM/dd HH:mm")
                            </p>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Location))
                    {
                        <p class="mb-3">
                            <i class="fas fa-map-marker-alt text-danger"></i>
                            <strong>مکان:</strong> @Model.Location
                        </p>
                    }

                    @if (Model.MaxParticipants > 0)
                    {
                        <p class="mb-3">
                            <i class="fas fa-users text-info"></i>
                            <strong>ظرفیت:</strong> @Model.MaxParticipants نفر
                        </p>
                    }

                    <hr>

                    <h5 class="mb-3">توضیحات</h5>
                    <div class="workshop-description">
                        @Html.Raw(Model.Description.Replace("\n", "<br>"))
                    </div>

                    @if (!string.IsNullOrEmpty(Model.RegistrationLink) && isUpcoming)
                    {
                        <div class="mt-4">
                            <a href="@Model.RegistrationLink" target="_blank" class="btn btn-success btn-lg">
                                <i class="fas fa-user-plus"></i>
                                ثبت‌نام در کارگاه
                            </a>
                        </div>
                    }
                </div>
            </div>

            <div class="mt-3">
                <a href="@Url.Action("Index")" class="btn btn-secondary">
                    <i class="fas fa-arrow-right"></i>
                    بازگشت به لیست کارگاه‌ها
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    .workshop-description {
        font-size: 1.1rem;
        line-height: 1.8;
        text-align: justify;
    }
</style>
