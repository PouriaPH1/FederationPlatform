@model LoginViewModel

@{
    ViewBag.Title = "ورود";
    Layout = null;
}

<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ورود | پلتفرم فدراسیون</title>
    <link href="https://fonts.googleapis.com/css2?family=Vazirmatn:wght@100..900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.rtl.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            font-family: 'Vazirmatn', Tahoma, Arial, sans-serif;
        }

        body {
            background: linear-gradient(135deg, #f0f7ff 0%, #e0f2fe 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-container {
            width: 100%;
            max-width: 450px;
        }

        .login-card {
            background: white;
            border-radius: 15px;
            box-shadow: 0 25px 50px rgba(30, 64, 175, 0.15);
            overflow: hidden;
        }

        .login-header {
            background: linear-gradient(135deg, #1E40AF 0%, #0EA5E9 100%);
            padding: 3rem 2rem;
            text-align: center;
            color: white;
        }

        .login-header i {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .login-header h2 {
            font-size: 1.75rem;
            margin-bottom: 0.25rem;
        }

        .login-header p {
            font-size: 0.9rem;
            opacity: 0.9;
        }

        .login-body {
            padding: 2.5rem;
        }

        .form-group {
            margin-bottom: 1.5rem;
        }

        .form-label {
            font-weight: 600;
            color: #374151;
            margin-bottom: 0.5rem;
            display: block;
        }

        .form-control {
            border: 2px solid #E5E7EB;
            border-radius: 8px;
            padding: 0.875rem 1rem;
            font-size: 0.9375rem;
            transition: all 0.2s;
        }

        .form-control:focus {
            outline: none;
            border-color: #1E40AF;
            box-shadow: 0 0 0 4px rgba(30, 64, 175, 0.1);
        }

        .btn-login {
            width: 100%;
            padding: 0.875rem;
            background: linear-gradient(135deg, #1E40AF 0%, #0EA5E9 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.3s;
            margin-top: 1rem;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(30, 64, 175, 0.4);
            color: white;
        }

        .form-check {
            margin-top: 1.5rem;
        }

        .form-check-input {
            border: 2px solid #E5E7EB;
        }

        .form-check-input:checked {
            background-color: #1E40AF;
            border-color: #1E40AF;
        }

        .form-check-label {
            font-size: 0.9rem;
        }

        .login-footer {
            padding: 1.5rem 2.5rem;
            background: #F9FAFB;
            text-align: center;
            border-top: 1px solid #E5E7EB;
        }

        .login-footer p {
            margin: 0;
            font-size: 0.9rem;
            color: #6B7280;
        }

        .login-footer a {
            color: #1E40AF;
            font-weight: 600;
            text-decoration: none;
        }

        .login-footer a:hover {
            text-decoration: underline;
        }

        .alert {
            border-radius: 8px;
            margin-bottom: 1.5rem;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-card">
            <div class="login-header">
                <i class="fas fa-sign-in-alt"></i>
                <h2>ورود</h2>
                <p>به پلتفرم فدراسیون خوش آمدید</p>
            </div>

            <div class="login-body">
                @if (!string.IsNullOrEmpty(Model?.ErrorMessage))
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        @Model.ErrorMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                <form method="post" asp-action="Login">
                    <div class="form-group">
                        <label class="form-label" asp-for="Username"></label>
                        <input type="text" class="form-control" asp-for="Username" placeholder="نام کاربری یا ایمیل" required>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="Password"></label>
                        <input type="password" class="form-control" asp-for="Password" placeholder="رمز عبور" required>
                    </div>

                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" asp-for="RememberMe" id="rememberMe">
                        <label class="form-check-label" for="rememberMe">
                            مرا یاد بسپار
                        </label>
                    </div>

                    <button type="submit" class="btn btn-login">
                        <i class="fas fa-sign-in-alt me-2"></i>ورود
                    </button>
                </form>
            </div>

            <div class="login-footer">
                <p>حساب کاربری ندارید؟ <a asp-action="Register">ثبت‌نام کنید</a></p>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
