@model UniversityListViewModel

@{
    ViewBag.Title = "دانشگاه‌ها";
}

<div class="page-header">
    <h1>دانشگاه‌ها</h1>
    <p>لیست تمام دانشگاه‌های عضو فدراسیون</p>
</div>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <form method="get" class="filter-form">
                <div class="input-group">
                    <input type="text" class="form-control" name="searchTerm" placeholder="جستجو در دانشگاه‌ها" value="@Model.SearchTerm">
                    <button class="btn btn-primary" type="submit">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </form>
        </div>
        <div class="col-md-6">
            <select class="form-select" onchange="window.location = '@Url.Action("Index", "University")?sortBy=' + this.value">
                <option value="">ترتیب بر اساس</option>
                <option value="name">نام</option>
                <option value="city">شهر</option>
                <option value="activities">فعالیت‌ها</option>
            </select>
        </div>
    </div>

    <div class="row">
        @if (Model.Universities.Any())
        {
            @foreach (var university in Model.Universities)
            {
                <div class="col-md-6 mb-4">
                    <div class="university-detail-card">
                        <div class="university-header-section">
                            <div class="university-icon">
                                <i class="fas fa-university"></i>
                            </div>
                            <div class="university-header-info">
                                <h3>@university.Name</h3>
                                <p class="location">
                                    <i class="fas fa-map-marker-alt me-2"></i>@university.City
                                </p>
                            </div>
                        </div>

                        <div class="university-stats">
                            <div class="stat-item">
                                <span class="stat-value">@university.ActivitiesCount</span>
                                <span class="stat-label">فعالیت</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-value">@university.MembersCount</span>
                                <span class="stat-label">عضو</span>
                            </div>
                            <div class="stat-item">
                                <span class="stat-value">@university.NewsCount</span>
                                <span class="stat-label">خبر</span>
                            </div>
                        </div>

                        <div class="university-footer">
                            <a href="@Url.Action("Details", "University", new { id = university.Id })" class="btn btn-primary">
                                <i class="fas fa-arrow-left me-2"></i>مشاهده جزئیات
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info text-center py-5">
                    <i class="fas fa-search" style="font-size: 3rem;"></i>
                    <p class="mt-3">دانشگاهی یافت نشد</p>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                @if (Model.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", "University", new { page = Model.CurrentPage - 1 })">
                            قبلی
                        </a>
                    </li>
                }
                
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", "University", new { page = i })">@i</a>
                    </li>
                }
                
                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", "University", new { page = Model.CurrentPage + 1 })">
                            بعدی
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

<style>
.page-header {
    background: linear-gradient(135deg, #1E40AF 0%, #0EA5E9 100%);
    color: white;
    padding: 2rem;
    margin-bottom: 2rem;
    border-radius: 12px;
}

.university-detail-card {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    transition: all 0.3s;
}

.university-detail-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(30, 64, 175, 0.2);
}

.university-header-section {
    display: flex;
    gap: 1.5rem;
    align-items: center;
    padding: 2rem;
    background: linear-gradient(135deg, #F3F4F6 0%, #E5E7EB 100%);
}

.university-icon {
    width: 70px;
    height: 70px;
    background: linear-gradient(135deg, #1E40AF 0%, #0EA5E9 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 2rem;
    flex-shrink: 0;
}

.university-header-info h3 {
    margin: 0;
    color: #1E40AF;
    font-size: 1.3rem;
}

.location {
    margin: 0.5rem 0 0;
    color: #6B7280;
    font-size: 0.9rem;
}

.university-stats {
    display: flex;
    justify-content: space-around;
    padding: 1.5rem;
    background: white;
    border-bottom: 1px solid #E5E7EB;
}

.stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
}

.stat-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1E40AF;
}

.stat-label {
    font-size: 0.8rem;
    color: #6B7280;
}

.university-footer {
    padding: 1.5rem 2rem;
    background: white;
}

.pagination {
    gap: 0.5rem;
}

.page-link {
    border-radius: 6px;
    color: #1E40AF;
    border: none;
}

.page-link:hover {
    background: #F3F4F6;
    color: #0EA5E9;
}

.page-item.active .page-link {
    background: linear-gradient(135deg, #1E40AF 0%, #0EA5E9 100%);
    border-color: transparent;
}
</style>
