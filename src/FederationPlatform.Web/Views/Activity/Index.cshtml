@model ActivityListViewModel

@{
    ViewBag.Title = "فعالیت‌ها";
}

<div class="page-header">
    <h1><i class="fas fa-tasks me-2"></i>فعالیت‌ها</h1>
    <p>مشاهده و جستجو در فعالیت‌های فدراسیون</p>
</div>

<div class="container-fluid py-4">
    <!-- Search & Filter Section -->
    <div class="search-filter-section mb-4" data-searchable="true" data-search-input="[data-search]" data-table-selector="tbody">
        <div class="row gap-3">
            <div class="col-lg-6">
                <div class="input-group input-group-lg">
                    <span class="input-group-text" style="border: 1px solid #D1D5DB;">
                        <i class="fas fa-search"></i>
                    </span>
                    <input type="text" 
                           class="form-control" 
                           data-search
                           placeholder="جستجو در عنوان و توضیحات..." 
                           style="border: 1px solid #D1D5DB; border-right: none;">
                </div>
            </div>
            <div class="col-lg-3">
                <select class="form-select form-select-lg" data-filter="status" style="border: 1px solid #D1D5DB;">
                    <option value="">-- همه وضعیت‌ها --</option>
                    <option value="Approved">تایید شده</option>
                    <option value="Pending">در انتظار</option>
                    <option value="Rejected">رد شده</option>
                </select>
            </div>
            <div class="col-lg-3">
                @if (User.IsInRole("Representative") || User.IsInRole("Admin"))
                {
                    <a href="@Url.Action("Create", "Activity")" class="btn btn-primary btn-lg w-100">
                        <i class="fas fa-plus me-2"></i>فعالیت جدید
                    </a>
                }
            </div>
        </div>

        <!-- Active Filters Info -->
        <div id="active-filters" style="margin-top: 1rem; display: none;">
            <small class="text-muted">
                <i class="fas fa-filter me-2"></i>
                فیلترهای فعال:
                <span id="filter-count">0</span>
            </small>
        </div>
    </div>

    <!-- Activities Grid -->
    <div class="activities-grid">
        @if (Model.Activities != null && Model.Activities.Any())
        {
            <div class="row">
                @foreach (var activity in Model.Activities)
                {
                    <div class="col-lg-4 col-md-6 mb-4 fade-in">
                        <div class="activity-card hover-lift">
                            <!-- Card Header -->
                            <div class="activity-header" style="padding: 1.5rem;">
                                <div class="d-flex justify-content-between align-items-start gap-2">
                                    <div style="flex: 1;">
                                        <h5 style="margin: 0 0 0.5rem 0; color: #1E40AF; font-weight: 600;">
                                            @activity.Title
                                        </h5>
                                        <p style="color: #666; font-size: 0.9rem; margin: 0;">
                                            <i class="fas fa-university me-1"></i>@activity.UniversityName
                                        </p>
                                    </div>
                                    <span class="badge bg-@GetStatusClass(activity.Status)" style="font-size: 0.8rem; white-space: nowrap;">
                                        @activity.Status
                                    </span>
                                </div>
                            </div>

                            <!-- Card Body -->
                            <div style="padding: 0 1.5rem; border-top: 1px solid #E5E7EB; border-bottom: 1px solid #E5E7EB;">
                                <p style="color: #666; font-size: 0.95rem; line-height: 1.5; margin: 1rem 0;">
                                    @{
                                        var desc = activity.Description.Length > 100 
                                            ? activity.Description.Substring(0, 100) + "..." 
                                            : activity.Description;
                                    }
                                    @Html.Raw(desc)
                                </p>
                            </div>

                            <!-- Card Footer -->
                            <div style="padding: 1rem 1.5rem; background-color: #F9FAFB; display: flex; gap: 1rem; flex-wrap: wrap;">
                                @if (activity.StartDate.HasValue)
                                {
                                    <div style="font-size: 0.85rem; color: #666;">
                                        <i class="fas fa-calendar-alt me-1" style="color: #1E40AF;"></i>
                                        @activity.StartDate.Value.ToString("yy/MM/dd")
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(activity.RepresentativeName))
                                {
                                    <div style="font-size: 0.85rem; color: #666;">
                                        <i class="fas fa-user me-1" style="color: #1E40AF;"></i>
                                        @activity.RepresentativeName
                                    </div>
                                }
                            </div>

                            <!-- Action Button -->
                            <div style="padding: 1rem 1.5rem;">
                                <a href="@Url.Action("Details", "Activity", new { id = activity.Id })" 
                                   class="btn btn-sm btn-outline-primary w-100 transition-all">
                                    <i class="fas fa-arrow-left me-2"></i>مشاهده جزئیات
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Pagination -->
            @if (Model.TotalPages > 1)
            {
                <nav aria-label="Page navigation" class="mt-4">
                    <ul class="pagination justify-content-center" style="gap: 0.5rem;">
                        @if (Model.CurrentPage > 1)
                        {
                            <li class="page-item">
                                <a class="page-link" href="?page=1&searchTerm=@Model.SearchTerm">
                                    <i class="fas fa-chevron-right me-1"></i>ابتدا
                                </a>
                            </li>
                            <li class="page-item">
                                <a class="page-link" href="?page=@(Model.CurrentPage - 1)&searchTerm=@Model.SearchTerm">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        }

                        @for (int i = Math.Max(1, Model.CurrentPage - 2); i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                        {
                            @if (i == Model.CurrentPage)
                            {
                                <li class="page-item active">
                                    <span class="page-link">@i</span>
                                </li>
                            }
                            else
                            {
                                <li class="page-item">
                                    <a class="page-link" href="?page=@i&searchTerm=@Model.SearchTerm">@i</a>
                                </li>
                            }
                        }

                        @if (Model.CurrentPage < Model.TotalPages)
                        {
                            <li class="page-item">
                                <a class="page-link" href="?page=@(Model.CurrentPage + 1)&searchTerm=@Model.SearchTerm">
                                    <i class="fas fa-chevron-left"></i>
                                </a>
                            </li>
                            <li class="page-item">
                                <a class="page-link" href="?page=@Model.TotalPages&searchTerm=@Model.SearchTerm">
                                    انتها<i class="fas fa-chevron-left me-1"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            }
        }
        else
        {
            <!-- Empty State -->
            @{
                ViewBag.Icon = "fas fa-search";
                ViewBag.Title = "فعالیتی یافت نشد";
                ViewBag.Message = "در حال حاضر فعالیتی تطابق دارد. بعداً دوباره بررسی کنید یا یک فعالیت جدید ایجاد کنید.";
                ViewBag.ActionUrl = User.IsInRole("Representative") ? Url.Action("Create", "Activity") : null;
                ViewBag.ActionIcon = "fas fa-plus";
                ViewBag.ActionText = "ایجاد فعالیت";
            }
            @await Html.PartialAsync("_EmptyState")
        }
    </div>
</div>

<style>
    .page-header {
        background: linear-gradient(135deg, #1E40AF 0%, #0EA5E9 100%);
        color: white;
        padding: 2rem;
        margin-bottom: 2rem;
        border-radius: 12px;
        box-shadow: 0 4px 15px rgba(30, 64, 175, 0.2);
    }

    .search-filter-section {
        background: white;
        padding: 1.5rem;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    }

    .activity-card {
        background: white;
        border-radius: 12px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        overflow: hidden;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .activity-card:hover {
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
        transform: translateY(-4px);
    }

    .badge {
        font-weight: 600;
        padding: 0.4rem 0.8rem;
        font-size: 0.8rem;
    }

    .bg-approved {
        background-color: #d1fae5 !important;
        color: #065f46 !important;
    }

    .bg-pending {
        background-color: #fef3c7 !important;
        color: #92400e !important;
    }

    .bg-rejected {
        background-color: #fee2e2 !important;
        color: #991b1b !important;
    }

    .activities-grid {
        animation: fadeIn 0.3s ease-in-out;
    }

    .pagination .page-link {
        color: #1E40AF;
        border: 1px solid #D1D5DB;
        border-radius: 6px;
    }

    .pagination .page-link:hover {
        background-color: #f0f9ff;
        border-color: #1E40AF;
    }

    .pagination .page-item.active .page-link {
        background-color: #1E40AF;
        border-color: #1E40AF;
    }

    .input-group-text {
        background-color: white;
        color: #1E40AF;
    }
</style>

@functions {
    private string GetStatusClass(string status)
    {
        return status switch
        {
            "تایید شده" => "success",
            "Approved" => "success",
            "در انتظار" => "warning",
            "Pending" => "warning",
            "رد شده" => "danger",
            "Rejected" => "danger",
            _ => "secondary"
        };
    }
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Initialize search and filter
            const config = {
                searchInputSelector: '[data-search]',
                filterSelectors: {
                    status: '[data-filter="status"]'
                },
                tableSelector: 'tbody',
                minChars: 1
            };

            if (window.SearchFilterManager) {
                const manager = new SearchFilterManager(config);
                
                // Listen for search complete event
                document.addEventListener('search-complete', function(e) {
                    const { visibleCount, totalCount } = e.detail;
                    const filterInfo = document.getElementById('active-filters');
                    if (visibleCount < totalCount) {
                        document.getElementById('filter-count').textContent = visibleCount;
                        filterInfo.style.display = 'block';
                    } else {
                        filterInfo.style.display = 'none';
                    }
                });
            }
        });
    </script>
}
                                @activity.ParticipantsCount
                            </span>
                        </div>
                        
                        <div class="activity-footer">
                            <a href="@Url.Action("Details", "Activity", new { id = activity.Id })" class="btn btn-sm btn-primary">
                                مشاهده جزئیات
                            </a>
                            @if ((User.Identity?.Name == activity.RepresentativeName || User.IsInRole("Admin")) && !activity.IsApproved)
                            {
                                <a href="@Url.Action("Edit", "Activity", new { id = activity.Id })" class="btn btn-sm btn-warning">
                                    ویرایش
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info text-center py-5">
                    <i class="fas fa-inbox" style="font-size: 3rem;"></i>
                    <p class="mt-3">فعالیتی یافت نشد</p>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                @if (Model.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", "Activity", new { page = Model.CurrentPage - 1 })">
                            قبلی
                        </a>
                    </li>
                }
                
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", "Activity", new { page = i })">@i</a>
                    </li>
                }
                
                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", "Activity", new { page = Model.CurrentPage + 1 })">
                            بعدی
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

<style>
.page-header {
    background: linear-gradient(135deg, #1E40AF 0%, #0EA5E9 100%);
    color: white;
    padding: 2rem;
    margin-bottom: 2rem;
    border-radius: 12px;
}

.page-header h1 {
    margin: 0;
    font-size: 2.5rem;
}

.page-header p {
    margin: 0.5rem 0 0;
    opacity: 0.9;
}

.filter-form .input-group {
    box-shadow: 0 4px 15px rgba(30, 64, 175, 0.1);
}

.activity-card {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    transition: all 0.3s;
    display: flex;
    flex-direction: column;
    height: 100%;
}

.activity-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(30, 64, 175, 0.2);
}

.activity-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
    gap: 1rem;
}

.activity-header h5 {
    margin: 0;
    flex: 1;
    color: #1E40AF;
}

.status-badge {
    padding: 0.35rem 0.75rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    white-space: nowrap;
}

.status-badge.approved {
    background: #D1FAE5;
    color: #065F46;
}

.status-badge.pending {
    background: #FEF3C7;
    color: #92400E;
}

.status-badge.rejected {
    background: #FEE2E2;
    color: #991B1B;
}

.activity-university {
    color: #6B7280;
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
}

.activity-description {
    color: #4B5563;
    font-size: 0.95rem;
    line-height: 1.5;
    margin-bottom: 1rem;
    flex: 1;
}

.activity-meta {
    display: flex;
    gap: 1.5rem;
    font-size: 0.85rem;
    color: #6B7280;
    margin-bottom: 1rem;
    flex-wrap: wrap;
}

.activity-meta span {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.activity-footer {
    display: flex;
    gap: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid #E5E7EB;
}

.pagination {
    gap: 0.5rem;
}

.page-link {
    border-radius: 6px;
    color: #1E40AF;
    border: none;
}

.page-link:hover {
    background: #F3F4F6;
    color: #0EA5E9;
}

.page-item.active .page-link {
    background: linear-gradient(135deg, #1E40AF 0%, #0EA5E9 100%);
    border-color: transparent;
}
</style>
