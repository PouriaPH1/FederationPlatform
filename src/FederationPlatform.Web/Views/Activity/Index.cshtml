@model ActivityListViewModel

@{
    ViewBag.Title = "فعالیت‌ها";
}

<div class="page-header">
    <h1>فعالیت‌ها</h1>
    <p>مشاهده و مدیریت فعالیت‌های فدراسیون</p>
</div>

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <form method="get" class="filter-form">
                <div class="input-group">
                    <input type="text" class="form-control" name="searchTerm" placeholder="جستجو در فعالیت‌ها" value="@Model.SearchTerm">
                    <button class="btn btn-primary" type="submit">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </form>
        </div>
        <div class="col-md-6 text-end">
            @if (User.IsInRole("Representative") || User.IsInRole("Admin"))
            {
                <a href="@Url.Action("Create", "Activity")" class="btn btn-success">
                    <i class="fas fa-plus me-2"></i>فعالیت جدید
                </a>
            }
        </div>
    </div>

    <div class="row">
        @if (Model.Activities.Any())
        {
            @foreach (var activity in Model.Activities)
            {
                <div class="col-md-4 mb-4">
                    <div class="activity-card">
                        <div class="activity-header">
                            <h5>@activity.Title</h5>
                            <span class="status-badge @activity.Status.ToLower()">@activity.Status</span>
                        </div>
                        
                        <p class="activity-university">
                            <i class="fas fa-university me-2"></i>@activity.UniversityName
                        </p>
                        
                        <p class="activity-description">
                            @Html.Raw(activity.Description.Length > 120 ? activity.Description.Substring(0, 120) + "..." : activity.Description)
                        </p>
                        
                        <div class="activity-meta">
                            <span>
                                <i class="fas fa-calendar"></i>
                                @activity.StartDate?.ToString("yyyy/MM/dd")
                            </span>
                            <span>
                                <i class="fas fa-users"></i>
                                @activity.ParticipantsCount
                            </span>
                        </div>
                        
                        <div class="activity-footer">
                            <a href="@Url.Action("Details", "Activity", new { id = activity.Id })" class="btn btn-sm btn-primary">
                                مشاهده جزئیات
                            </a>
                            @if ((User.Identity?.Name == activity.RepresentativeName || User.IsInRole("Admin")) && !activity.IsApproved)
                            {
                                <a href="@Url.Action("Edit", "Activity", new { id = activity.Id })" class="btn btn-sm btn-warning">
                                    ویرایش
                                </a>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-info text-center py-5">
                    <i class="fas fa-inbox" style="font-size: 3rem;"></i>
                    <p class="mt-3">فعالیتی یافت نشد</p>
                </div>
            </div>
        }
    </div>

    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation" class="mt-4">
            <ul class="pagination justify-content-center">
                @if (Model.CurrentPage > 1)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", "Activity", new { page = Model.CurrentPage - 1 })">
                            قبلی
                        </a>
                    </li>
                }
                
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" href="@Url.Action("Index", "Activity", new { page = i })">@i</a>
                    </li>
                }
                
                @if (Model.CurrentPage < Model.TotalPages)
                {
                    <li class="page-item">
                        <a class="page-link" href="@Url.Action("Index", "Activity", new { page = Model.CurrentPage + 1 })">
                            بعدی
                        </a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

<style>
.page-header {
    background: linear-gradient(135deg, #1E40AF 0%, #0EA5E9 100%);
    color: white;
    padding: 2rem;
    margin-bottom: 2rem;
    border-radius: 12px;
}

.page-header h1 {
    margin: 0;
    font-size: 2.5rem;
}

.page-header p {
    margin: 0.5rem 0 0;
    opacity: 0.9;
}

.filter-form .input-group {
    box-shadow: 0 4px 15px rgba(30, 64, 175, 0.1);
}

.activity-card {
    background: white;
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    transition: all 0.3s;
    display: flex;
    flex-direction: column;
    height: 100%;
}

.activity-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(30, 64, 175, 0.2);
}

.activity-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
    gap: 1rem;
}

.activity-header h5 {
    margin: 0;
    flex: 1;
    color: #1E40AF;
}

.status-badge {
    padding: 0.35rem 0.75rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
    white-space: nowrap;
}

.status-badge.approved {
    background: #D1FAE5;
    color: #065F46;
}

.status-badge.pending {
    background: #FEF3C7;
    color: #92400E;
}

.status-badge.rejected {
    background: #FEE2E2;
    color: #991B1B;
}

.activity-university {
    color: #6B7280;
    font-size: 0.9rem;
    margin-bottom: 0.75rem;
}

.activity-description {
    color: #4B5563;
    font-size: 0.95rem;
    line-height: 1.5;
    margin-bottom: 1rem;
    flex: 1;
}

.activity-meta {
    display: flex;
    gap: 1.5rem;
    font-size: 0.85rem;
    color: #6B7280;
    margin-bottom: 1rem;
    flex-wrap: wrap;
}

.activity-meta span {
    display: flex;
    align-items: center;
    gap: 0.5rem;
}

.activity-footer {
    display: flex;
    gap: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid #E5E7EB;
}

.pagination {
    gap: 0.5rem;
}

.page-link {
    border-radius: 6px;
    color: #1E40AF;
    border: none;
}

.page-link:hover {
    background: #F3F4F6;
    color: #0EA5E9;
}

.page-item.active .page-link {
    background: linear-gradient(135deg, #1E40AF 0%, #0EA5E9 100%);
    border-color: transparent;
}
</style>
