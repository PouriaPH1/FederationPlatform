{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=FederationPlatformDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*",
  "FileUpload": {
    "MaxFileSizeInMB": 10,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".pdf", ".doc", ".docx"],
    "UploadPath": "wwwroot/uploads"
  },
  "ApplicationSettings": {
    "ApplicationName": "پلتفرم مدیریت فعالیت‌های کمیته دانشجویی",
    "SupportEmail": "support@federation.ir",
    "DefaultAdminEmail": "admin@federation.ir",
    "DefaultAdminPassword": "Admin@123456"
  }
}
